# ── Zee AI v2 Configuration ───────────────────────────────────────────────────

# Ollama backend or Cloud API
# For local  Ollama: http://localhost:11434
# For remote Ollama: http://<REMOTE_IP>:11434
# For Groq API:      https://api.groq.com/openai/v1
# For Grok (xAI):    https://api.x.ai/v1
OLLAMA_HOST=http://localhost:11434

# API Key (Only required for Groq or Grok — leave blank for Ollama)
XAI_API_KEY=

# Vision/chat model
# Ollama recommended: qwen2-vl
# Groq recommended:   llama-3.3-70b-versatile  (or meta-llama/llama-4-scout-17b-16e-instruct for vision)
# Grok recommended:   grok-2-vision-1212
ZEE_MODEL=qwen2-vl

# WebSocket server port
ZEE_WS_PORT=8765

# SearXNG self-hosted search (optional — falls back to DuckDuckGo)
SEARXNG_URL=http://localhost:8888

# Wake word model (hey_jarvis, hey_zee, etc. — searches in scripts/models/)
WAKE_WORD_MODEL=hey_jarvis
WAKE_THRESHOLD=0.5

# Whisper STT model size (tiny, base, small, medium)
WHISPER_MODEL=base

# Piper TTS voice
PIPER_VOICE=en_US-ryan-medium
PIPER_MODEL_DIR=%USERPROFILE%\.local\share\piper-tts
