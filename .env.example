# ── Zee AI v2 Configuration ───────────────────────────────────────────────────

# Ollama backend (local or ngrok tunnel)
OLLAMA_HOST=http://localhost:11434

# Vision/chat model (qwen2-vl recommended)
ZEE_MODEL=qwen2-vl

# WebSocket server port
ZEE_WS_PORT=8765

# SearXNG self-hosted search (optional — falls back to DuckDuckGo)
SEARXNG_URL=http://localhost:8888

# Wake word model (hey_jarvis, hey_zee, etc. — searches in scripts/models/)
WAKE_WORD_MODEL=hey_jarvis
WAKE_THRESHOLD=0.5

# Whisper STT model size (tiny, base, small, medium)
WHISPER_MODEL=base

# Piper TTS voice
PIPER_VOICE=en_US-ryan-medium
PIPER_MODEL_DIR=%USERPROFILE%\.local\share\piper-tts
